# ─── BizChat Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in values.
# On Railway: add these directly in the Railway dashboard → Variables tab.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app  # Your Vercel frontend URL

# ── Firebase / Firestore ───────────────────────────────────────────────────────
# Paste the ENTIRE contents of firebase-service-account.json here as one line.
# On Railway: use the "Raw" variable editor, paste the JSON directly.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ── AI / Ollama ────────────────────────────────────────────────────────────────
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_HOST=https://ollama.com
AI_MODEL_FAST=minimax-m2.1:cloud
AI_MODEL_SMART=minimax-m2.1:cloud

# ── Business Defaults (shown on invoices before settings are saved) ────────────
DEFAULT_BUSINESS_NAME=My Store
DEFAULT_GST_NUMBER=22AAAAA0000A1Z5

# ── Optional: Neon Auth (if using JWT-based auth) ─────────────────────────────
# NEON_AUTH_URL=https://your-neon-project.neon.tech
# NEON_JWKS_URL=https://your-neon-project.neon.tech/.well-known/jwks.json

# ── Optional: Azure Blob Storage (for PDF invoice uploads) ────────────────────
# AZURE_STORAGE_ACCOUNT_NAME=your_account
# AZURE_STORAGE_ACCOUNT_KEY=your_key
# AZURE_STORAGE_CONTAINER_NAME=invoices

# ── Optional: Sentry Error Tracking ───────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyyy
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# NODE_OLD_SPACE_SIZE=256
