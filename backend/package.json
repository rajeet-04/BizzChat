{
  "name": "bizchat-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite-node --watch src/index.ts",
    "dev:worker": "vite-node --watch src/worker.ts",
    "build": "tsc && node fix-imports.js",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "start:pm2:watch": "pm2 start ecosystem.config.js --watch",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs",
    "start:worker": "node dist/worker.js",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project integration",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.40.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.8.0",
    "google-libphonenumber": "^3.2.44",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
    "ollama": "^0.6.3",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.39.0",
    "socket.io": "^4.8.3",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "pm2": "^5.4.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.16.5",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.24.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
