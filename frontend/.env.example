# ─── BizChat Frontend — Environment Variables ─────────────────────────────────
# Copy to .env.local for local dev, or add in Vercel Dashboard → Settings → Env Vars

# The Railway backend URL. Leave empty for local dev (Vite proxy handles it).
# In production: set to your Railway backend URL, e.g.:
# VITE_API_URL=https://bizchat-backend.up.railway.app
VITE_API_URL=
